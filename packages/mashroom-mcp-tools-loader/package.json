{
  "name": "mashroom-mcp-tools-loader",
  "version": "1.0.0",
  "private": true,
  "author": "Milan Heimschild",
  "license": "MIT",
  "type": "module",
  "repository": {
    "url": "https://github.com/mheimschild/mashroom-mcp"
  },
  "keywords": [
    "Mashroom",
    "Plugin Loader",
    "MCP"
  ],
  "files": [
    "dist/*.js",
    "mashroom.json"
  ],
  "scripts": {
    "build": "rsbuild build",
    "check": "biome check --write",
    "type-check": "tsc --noEmit",
    "dev": "rsbuild dev --open",
    "format": "biome format --write",
    "preview": "rsbuild preview",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "prepublishOnly": "npm run check && npm run type-check"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@mashroom/mashroom": "^2.9.4",
    "@rsbuild/core": "^1.7.1",
    "@rstest/core": "^0.7.8",
    "typescript": "^5.9.3"
  }
}
